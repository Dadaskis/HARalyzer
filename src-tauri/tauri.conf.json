{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HARalyzer",
  "version": "1.0.0",
  "identifier": "com.haralyzer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HARalyzer",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "backgroundColor": "#0e0918"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    },
    "fileAssociations": [
      {
        "ext": ["har"],
        "name": "HTTP Archive",
        "description": "HTTP Archive (HAR) capture file",
        "mimeType": "application/json",
        "role": "Editor"
      }
    ]
  }
}
